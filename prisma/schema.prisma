generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String               @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  role                Role                 @default(STUDENT)
  isApproved          Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  studentType         StudentType          @default(ONLINE)
  level               Level                @default(BASIC)
  accounts            Account[]
  comments            Comment[]
  courses             Course[]
  enrollments         Enrollment[]
  homeworkSubmissions HomeworkSubmission[]
  notifications       Notification[]
  progress            Progress[]
  sessions            Session[]
  attempts            StudentAttempt[]
  tests               Test[]
  videoAssets         VideoAsset[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  courses Course[]
}

model Course {
  id           String       @id @default(cuid())
  userId       String
  title        String
  description  String?
  thumbnail    String?
  price        Float?
  examDate     DateTime?
  isPublished  Boolean      @default(false)
  isStructured Boolean      @default(true)
  categoryId   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  level        Level        @default(BASIC)
  attachments  Attachment[]
  chapters     Chapter[]
  category     Category?    @relation(fields: [categoryId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments  Enrollment[]
  finalTest    Test?        @relation("CourseFinalTest")

  @@index([categoryId])
}

model Chapter {
  id          String   @id @default(cuid())
  title       String
  description String?
  position    Int      @default(0)
  isPublished Boolean  @default(false)
  isHidden    Boolean  @default(false)
  courseId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  @@index([courseId])
}

model Lesson {
  id                  String               @id @default(cuid())
  title               String
  description         String?
  videoUrl            String?
  position            Int                  @default(0)
  isPublished         Boolean              @default(false)
  isFree              Boolean              @default(false)
  type                LessonType           @default(VIDEO)
  muxData             String?
  duration            Int?
  chapterId           String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  hasHomework         Boolean              @default(false)
  homeworkVideoUrl    String?
  attachments         Attachment[]
  comments            Comment[]
  homeworkSubmissions HomeworkSubmission[]
  chapter             Chapter              @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  progress            Progress[]
  test                Test?

  @@index([chapterId])
}

model HomeworkSubmission {
  id          String         @id @default(cuid())
  userId      String
  lessonId    String
  attachments Json[]
  status      HomeworkStatus @default(PENDING)
  feedback    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lesson      Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
}

model Attachment {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String
  courseId  String?
  lessonId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([lessonId])
}

model Progress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  watchedTime Int      @default(0)
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  isEdited  Boolean   @default(false)
  userId    String
  lessonId  String
  parentId  String?
  images    String[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lesson    Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  children  Comment[] @relation("CommentReplies")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([userId])
  @@index([parentId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  link      String?
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Enrollment {
  id        String           @id @default(cuid())
  userId    String
  courseId  String
  status    EnrollmentStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model VideoAsset {
  id        String   @id @default(cuid())
  fileName  String   @unique
  title     String
  url       String
  size      BigInt
  status    String   @default("READY")
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Test {
  id             String           @id @default(cuid())
  title          String?
  subject        String?
  description    String?
  passScore      Float?
  accessCode     String?
  userId         String?
  lessonId       String?          @unique
  courseId       String?          @unique
  pdfUrl         String
  duration       Int
  showAnswers    Boolean          @default(false)
  explanation    String?
  videoUrl       String?
  audioUrl       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  dueDate        DateTime?
  solutionVideos Json?
  attempts       StudentAttempt[]
  course         Course?          @relation("CourseFinalTest", fields: [courseId], references: [id], onDelete: Cascade)
  lesson         Lesson?          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user           User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections       TestSection[]
}

model TestSection {
  id        String     @id @default(cuid())
  testId    String
  name      String
  position  Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  questions Question[]
  test      Test       @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
}

model Question {
  id                 String          @id @default(cuid())
  sectionId          String
  position           Int             @default(0)
  type               QuestionType    @default(MULTIPLE_CHOICE)
  correctAnswer      String?
  points             Float           @default(1.0)
  explanation        String?
  videoUrl           String?
  audioUrl           String?
  needsManualGrading Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  category           String?
  difficulty         String          @default("Medium")
  subCategory        String?
  section            TestSection     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  studentAnswers     StudentAnswer[]
  subQuestions       SubQuestion[]

  @@index([sectionId])
}

model StudentAttempt {
  id          String          @id @default(cuid())
  userId      String
  testId      String
  score       Float?
  startedAt   DateTime        @default(now())
  completedAt DateTime?
  answers     StudentAnswer[]
  test        Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([testId])
}

model StudentAnswer {
  id             String         @id @default(cuid())
  attemptId      String
  questionId     String
  answerProvided String?
  isCorrect      Boolean?
  pointsAwarded  Float          @default(0)
  feedback       String?
  attempt        StudentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  subAnswers     StudentSubAnswer[]

  @@unique([attemptId, questionId])
}

model SubQuestion {
  id            String          @id @default(cuid())
  questionId    String
  content       String?
  correctAnswer String
  type          SubQuestionType @default(TRUE_FALSE)
  position      Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  question      Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentSubAnswers StudentSubAnswer[]

  @@index([questionId])
}

model StudentSubAnswer {
  id              String        @id @default(cuid())
  studentAnswerId String
  subQuestionId   String
  answerProvided  String?
  isCorrect       Boolean?

  studentAnswer   StudentAnswer @relation(fields: [studentAnswerId], references: [id], onDelete: Cascade)
  subQuestion     SubQuestion   @relation(fields: [subQuestionId], references: [id], onDelete: Cascade)

  @@unique([studentAnswerId, subQuestionId])
  @@index([studentAnswerId])
}

enum Role {
  ADMIN
  STUDENT
  TEACHER
}

enum StudentType {
  ONLINE
  OFFLINE
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum LessonType {
  VIDEO
  DOCUMENT
  QUIZ
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
  ESSAY
  TRUE_FALSE
  MULTIPLE_CHOICE_GROUP
}

enum SubQuestionType {
  TRUE_FALSE
  MULTIPLE_CHOICE
  SHORT_ANSWER
}

enum HomeworkStatus {
  PENDING
  SATISFACTORY
  UNSATISFACTORY
}

enum NotificationType {
  COMMENT
  REPLY
  SYSTEM
}

enum Level {
  BASIC
  ADVANCED
}
