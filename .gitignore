# --- DEPENDENCIES ---
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- NEXT.JS & BUILD ---
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# --- IMPORTANT: SECURITY & ENV ---
# Chặn tất cả các file .env để không lộ mật khẩu Database và API Keys
.env
.env.local
.env.production
.env.development
.env*.local

# Chặn file chứa các chứng chỉ bảo mật, key cá nhân
*.pem
*.key
*.pub
*.cert
.ssh/

# --- DATABASE / PRISMA ---
# Không đẩy file SQLite cục bộ (nếu có dùng)
*.db
*.db-journal
/app/generated/prisma

# --- OS & DEBUG ---
.DS_Store
Thumbs.db
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- VERCEL / DOCKER ---
.vercel
.docker/
# Không chặn docker-compose.yml vì cần để deploy, 
# nhưng mật khẩu nên để trong .env thay vì viết thẳng vào compose.